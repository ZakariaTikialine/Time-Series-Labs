# Données
X <- c(23.1,25.6,27.2,24.5,25.1,26.6,23.2,24.9,
24.8,23.6,26.2,24.5,25.4,27.3,26.5,23.5,25.1)
Y <- c(12.9,13.5,14.2,14.3,14.7,14.8,16.2,15.1,
15.8,17.2,15.9,16.3,17.3,17.9,18.9,18.2,18.5)
n <- length(X)
# T1 – Lissage Exponentiel Simple
lissage.exponentiel.simple <- function(serie, a) {
n       <- length(serie)
lissage <- numeric(n)
lissage[1] <- serie[1]          # initialisation : S1 = X1
for (t in 2:n) {
lissage[t] <- a * serie[t] + (1 - a) * lissage[t - 1]
}
return(lissage)
}
# T2 – Lissage Exponentiel Double
lissage.exponentiel.double <- function(serie, a) {
n  <- length(serie)
S1 <- numeric(n)
S2 <- numeric(n)
x_prediction <- numeric(n)
# Initialisation
S1[1] <- serie[1]
S2[1] <- serie[1]
x_prediction[1] <- serie[1]
for (t in 2:n) {
S1[t] <- a * serie[t]  + (1 - a) * S1[t - 1]
S2[t] <- a * S1[t]     + (1 - a) * S2[t - 1]
# Coefficients
at <- 2 * S1[t] - S2[t]
bt <- (a / (1 - a)) * (S1[t] - S2[t])
x_prediction[t] <- at + bt   # prévision à 1 pas
}
return(x_prediction)
}
# T4 – Représentation graphique
par(mfrow = c(2, 1), mar = c(4, 4, 3, 1))
plot(1:n, X, type = "b", col = "steelblue", pch = 16,
main = "Série X  (stationnaire – pas de tendance marquée)",
xlab = "Temps t", ylab = "X_t", ylim = c(20, 30))
grid()
plot(1:n, Y, type = "b", col = "tomato", pch = 16,
main = "Série Y  (tendance croissante)",
xlab = "Temps t", ylab = "Y_t", ylim = c(12, 20))
grid()
par(mfrow = c(1, 1))
# T5 – Choix de méthode & justification
cat("=== T5 : Choix de méthode ===\n\n")
cat("Série X :\n")
cat("  → Lissage Exponentiel SIMPLE\n")
cat("  Justification : La série X oscille autour d'une moyenne\n")
cat("  stable (~25) sans tendance ni saisonnalité détectable.\n")
cat("  Le LES convient pour les séries stationnaires.\n\n")
cat("Série Y :\n")
cat("  → Lissage Exponentiel DOUBLE (méthode de Brown)\n")
cat("  Justification : La série Y présente une tendance\n")
cat("  croissante régulière (~12.9 → 18.5). Le LED capture\n")
cat("  la pente locale et améliore les prévisions.\n\n")
# T6 – Estimation du (n+1)-ème terme
alphas <- c(0.3, 0.8)
cat("=== T6 : Prévision du 18ème terme ===\n\n")
for (a in alphas) {
cat(sprintf("--- α = %.1f ---\n", a))
# -- Série X : LES --
lx <- lissage.exponentiel.simple(X, a)
pred_X <- lx[n]   # S_n est la prévision de X_{n+1}
cat(sprintf("  X̂_{18} (LES)  = %.4f\n", pred_X))
# -- Série Y : LED (Brown) --
S1 <- numeric(n); S2 <- numeric(n)
S1[1] <- Y[1]; S2[1] <- Y[1]
for (t in 2:n) {
S1[t] <- a * Y[t]  + (1 - a) * S1[t - 1]
S2[t] <- a * S1[t] + (1 - a) * S2[t - 1]
}
at <- 2 * S1[n] - S2[n]
bt <- (a / (1 - a)) * (S1[n] - S2[n])
pred_Y <- at + bt    # prévision 1 pas en avant
cat(sprintf("  Ŷ_{18} (LED)  = %.4f\n\n", pred_Y))
}
# Visualisation lissages + prévisions
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1))
for (a in alphas) {
# Série X
lx <- lissage.exponentiel.simple(X, a)
pred_X <- lx[n]
plot(1:n, X, type = "b", pch = 16, col = "steelblue",
xlim = c(1, n + 1), ylim = c(20, 30),
main = sprintf("Série X – LES  α=%.1f", a),
xlab = "t", ylab = "X_t")
lines(1:n, lx, col = "orange", lwd = 2)
points(n + 1, pred_X, pch = 17, col = "red", cex = 1.5)
legend("topright", legend = c("Observé","Lissé","Prévision"),
col = c("steelblue","orange","red"), lty = c(1,1,NA),
pch = c(16,NA,17), cex = 0.8)
grid()
# Série Y
ly <- lissage.exponentiel.double(Y, a)
S1 <- numeric(n); S2 <- numeric(n)
S1[1] <- Y[1]; S2[1] <- Y[1]
for (t in 2:n) {
S1[t] <- a * Y[t]  + (1 - a) * S1[t - 1]
S2[t] <- a * S1[t] + (1 - a) * S2[t - 1]
}
at <- 2 * S1[n] - S2[n]
bt <- (a / (1 - a)) * (S1[n] - S2[n])
pred_Y <- at + bt
plot(1:n, Y, type = "b", pch = 16, col = "tomato",
xlim = c(1, n + 1), ylim = c(12, 21),
main = sprintf("Série Y – LED  α=%.1f", a),
xlab = "t", ylab = "Y_t")
lines(1:n, ly, col = "darkgreen", lwd = 2)
points(n + 1, pred_Y, pch = 17, col = "red", cex = 1.5)
legend("topleft", legend = c("Observé","Lissé","Prévision"),
col = c("tomato","darkgreen","red"), lty = c(1,1,NA),
pch = c(16,NA,17), cex = 0.8)
grid()
}
par(mfrow = c(1, 1))
for (a in alphas) {
cat(sprintf("--- α = %.1f ---\n", a))
# -- Série X : LES --
lx <- lissage.exponentiel.simple(X, a)
pred_X <- lx[n]   # S_n est la prévision de X_{n+1}
cat(sprintf("  X̂_{18} (LES)  = %.4f\n", pred_X))
# -- Série Y : LED (Brown) --
S1 <- numeric(n); S2 <- numeric(n)
S1[1] <- Y[1]; S2[1] <- Y[1]
for (t in 2:n) {
S1[t] <- a * Y[t]  + (1 - a) * S1[t - 1]
S2[t] <- a * S1[t] + (1 - a) * S2[t - 1]
}
at <- 2 * S1[n] - S2[n]
bt <- (a / (1 - a)) * (S1[n] - S2[n])
pred_Y <- at + bt    # prévision 1 pas en avant
cat(sprintf("  Ŷ_{18} (LED)  = %.4f\n\n", pred_Y))
}
# Visualisation lissages + prévisions
